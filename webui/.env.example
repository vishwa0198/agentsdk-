# ── Required ──────────────────────────────────────────────────────────────────
# LLM provider API key (Groq is the default; swap in any compatible provider).
GROQ_API_KEY=gsk_your_key_here

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# Comma-separated list of allowed CORS origins (no trailing slash).
# In production set this to your actual domain, e.g. https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────
# Uncomment if Docker-in-Docker is unavailable (disables Python sandbox isolation).
# AGENTSDK_UNSAFE_PYTHON=1

# LLM model override (defaults to llama-3.3-70b-versatile via Groq).
# LLM_MODEL=llama-3.3-70b-versatile
