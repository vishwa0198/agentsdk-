# ── Required ──────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# Comma-separated list of allowed CORS origins (no trailing slash).
# In production set this to your actual domain, e.g. https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Ollama ─────────────────────────────────────────────────────────────────────
# URL of your Ollama server.
# • Local dev (no Docker): leave unset — defaults to http://localhost:11434
# • Running via docker-compose: use http://host.docker.internal:11434
#   (Docker Desktop on Windows/Mac routes this to your host machine automatically)
OLLAMA_HOST=http://host.docker.internal:11434

# Ollama model to use (must already be pulled: `ollama pull llama3:8b`)
OLLAMA_MODEL=llama3:8b

# ── Optional ──────────────────────────────────────────────────────────────────
# Uncomment if Docker-in-Docker is unavailable (disables Python sandbox isolation).
# AGENTSDK_UNSAFE_PYTHON=1
